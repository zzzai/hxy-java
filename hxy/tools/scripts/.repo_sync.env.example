# 复制为 .repo_sync.env（该文件已在 .gitignore 中忽略）

# GitHub 凭证（只用于本机，不入库）
GITHUB_USER=zzzai
GITHUB_TOKEN=__REPLACE_WITH_NEW_TOKEN__

# repo_sync.sh 可覆盖参数
ROOT_REPO=/root/crmeb-java
INNER_REPO=/root/crmeb-java/crmeb_java
ROOT_REMOTE=origin
ROOT_BRANCH=main
INNER_REMOTE=origin
INNER_BRANCH=1.4
CMD_TIMEOUT_SEC=30
