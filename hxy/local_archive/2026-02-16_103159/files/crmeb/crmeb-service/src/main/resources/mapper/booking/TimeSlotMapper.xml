<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zbkj.service.dao.TimeSlotDao">
    
    <resultMap id="BaseResultMap" type="com.zbkj.common.model.booking.TimeSlotPO">
        <id column="id" property="id"/>
        <result column="technician_id" property="technicianId"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="available" property="available"/>
        <result column="booking_id" property="bookingId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>
    
    <select id="findByTechnicianAndDate" resultMap="BaseResultMap">
        SELECT * FROM eb_time_slot
        WHERE technician_id = #{technicianId}
        AND DATE(start_time) = DATE(#{date})
        ORDER BY start_time
    </select>
    
    <select id="findAvailableSlots" resultMap="BaseResultMap">
        SELECT * FROM eb_time_slot
        WHERE technician_id = #{technicianId}
        AND available = 1
        AND start_time >= #{startTime}
        AND end_time &lt;= #{endTime}
        ORDER BY start_time
    </select>
    
</mapper>

