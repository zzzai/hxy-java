COMPOSE_PROJECT_NAME=hxy-platform
MYSQL_CONTAINER_NAME=hxy-mysql
REDIS_CONTAINER_NAME=hxy-redis
SERVER_CONTAINER_NAME=hxy-server
ADMIN_CONTAINER_NAME=hxy-admin
SERVER_IMAGE_NAME=hxy-server
ADMIN_IMAGE_NAME=hxy-admin
REDIS_IMAGE=redis:7-alpine
MYSQL_VOLUME_NAME=hxy-platform_mysql
REDIS_VOLUME_NAME=hxy-platform_redis
UI_REPO_URL=https://gitee.com/yudaocode/yudao-ui-admin-vue3.git
UI_REPO_REF=master

## mysql
MYSQL_DATABASE=hxy_dev
MYSQL_ROOT_PASSWORD=123456
MYSQL_HOST_PORT=13306

## server
CRMEB_COMPAT_STAGE=payment-core-only
SPRING_PROFILES_ACTIVE=local,crmeb-fast-track
JAVA_OPTS=-Xms512m -Xmx512m -Djava.security.egd=file:/dev/./urandom
SERVER_HOST_PORT=14880

MASTER_DATASOURCE_URL=jdbc:mysql://hxy-mysql:3306/${MYSQL_DATABASE}?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&nullCatalogMeansCurrent=true
MASTER_DATASOURCE_USERNAME=root
MASTER_DATASOURCE_PASSWORD=${MYSQL_ROOT_PASSWORD}
SLAVE_DATASOURCE_URL=${MASTER_DATASOURCE_URL}
SLAVE_DATASOURCE_USERNAME=${MASTER_DATASOURCE_USERNAME}
SLAVE_DATASOURCE_PASSWORD=${MASTER_DATASOURCE_PASSWORD}
REDIS_HOST=hxy-redis
REDIS_HOST_PORT=16379
TRADE_EXPRESS_KD100_KEY=dummy
TRADE_EXPRESS_KD100_CUSTOMER=dummy
TRADE_EXPRESS_KDNIAO_API_KEY=dummy
TRADE_EXPRESS_KDNIAO_BUSINESS_ID=dummy

## admin
ADMIN_HOST_PORT=18080
NODE_ENV=production
PUBLIC_PATH=/
VUE_APP_TITLE=荷小悦
VUE_APP_BASE_API=/prod-api
VUE_APP_APP_NAME=/
VUE_APP_TENANT_ENABLE=true
VUE_APP_CAPTCHA_ENABLE=true
VUE_APP_DOC_ENABLE=true
VUE_APP_BAIDU_CODE=fadc1bd5db1a1d6f581df60a1807f8ab
VITE_APP_TITLE=荷小悦
VITE_BASE_URL=
VITE_API_URL=/prod-api/admin-api
VITE_BASE_PATH=/
