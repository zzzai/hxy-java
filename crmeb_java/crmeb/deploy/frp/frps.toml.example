# 公网服务器 frps 配置示例
# 机器角色：115.190.245.14（运行 Nginx + frps）

bindPort = 7000

auth.method = "token"
auth.token = "REPLACE_ME_WITH_LONG_RANDOM_TOKEN"

# 强制 frpc->frps 使用 TLS
transport.tls.force = true

# 建议把代理暴露端口仅绑定到回环地址，避免被公网直接访问
# 需要 frp 版本支持该参数
proxyBindAddr = "127.0.0.1"

# 可选：限制 frpc 仅能申请指定端口
# allowPorts = [{ start = 32000, end = 32010 }]

# 可选：Dashboard
# webServer.addr = "127.0.0.1"
# webServer.port = 7500
# webServer.user = "admin"
# webServer.password = "REPLACE_ME"
